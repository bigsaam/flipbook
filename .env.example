# Copy to .env for local development. Never commit the real file.

# From @BotFather after /newbot. Also run /setinline to enable inline mode.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# From partner.klipy.com -> API Keys -> Add Platform.
# Test keys allow 100 calls/hour; request production access in the panel for unlimited.
KLIPY_API_KEY=

# Shared secret Telegram echoes back on every webhook call, so the endpoint
# can reject anything that did not come from Telegram.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Public HTTPS hostname, no scheme. Railway injects RAILWAY_PUBLIC_DOMAIN
# automatically once a domain is generated, so this is only needed elsewhere.
# PUBLIC_DOMAIN=flipbook.up.railway.app

# --- Optional tuning ---
# Content rating ceiling: g, pg, pg-13, r
KLIPY_RATING=pg-13
# Locale for trending results (ISO 3166 alpha-2, underscore form)
KLIPY_LOCALE=en_US
# Results per inline page (8-50)
FLIPBOOK_PER_PAGE=30
# Seconds Telegram may cache a result set
FLIPBOOK_CACHE_TIME=300
# Local port; Railway sets PORT itself
PORT=8080
